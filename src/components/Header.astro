---
import { SITE_TITLE } from '../consts';

// Highlights the current section in the nav. Blog and Why I Built It each
// have multiple real routes (post pages, the ES twin, the old /about
// redirect), so "active" is a prefix match against all of them rather
// than an exact string compare.
const path = Astro.url.pathname;
const startsWith = (base) => path === base || path.startsWith(`${base}/`);
const navItems = [
  { href: '/', label: 'Home', active: path === '/' },
  { href: '/blog', label: 'Blog', active: startsWith('/blog') || startsWith('/en/blog') || startsWith('/es/blog') },
  { href: '/claim-decoder', label: 'Claim Decoder', active: startsWith('/claim-decoder') },
  { href: '/why-i-built-it', label: 'Why I Built It', active: startsWith('/why-i-built-it') || startsWith('/es/why-i-built-it') || startsWith('/about') },
];
---

<header>
  <nav>
    <div class="logo">
      <a href="/">Pore <span class="teal">Scale</span><span class="dot">•</span></a>
    </div>
    <div class="nav-links">
      {navItems.map((item) => (
        <a href={item.href} class:list={[{ active: item.active }]}>{item.label}</a>
      ))}
    </div>
  </nav>
</header>

<style>
  header {
    /* Kept flat rather than the diagonal gradient tried earlier: on
       mobile the nav wraps and leaves unused width in the bar, and a
       diagonal gradient turns that unused width into an obvious blank
       coral patch. The vivid part now lives entirely in the underline
       bar below, which doesn't depend on how much space text fills. */
    background: #f0f7f5;
    position: relative;
    padding: 0 2em;
  }
  header::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background: linear-gradient(90deg, #2d9e88, #ff6b6b, #f0a500);
  }
  nav {
    max-width: 720px;
    margin: auto;
    padding: 1em 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }
  .logo a {
    font-size: 17px;
    font-weight: 500;
    color: #1a3a34;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .teal {
    color: #2d9e88;
  }
  .dot {
    color: #ff6b6b;
    margin-left: 3px;
    font-size: 20px;
  }
  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: #4a7a72;
    text-decoration: none;
    letter-spacing: 0.02em;
    padding-bottom: 3px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .nav-links a:hover {
    color: #1a3a34;
  }
  .nav-links a.active {
    color: #1a3a34;
    font-weight: 600;
    border-bottom-color: #ff6b6b;
  }

  @media (max-width: 640px) {
    nav {
      flex-wrap: wrap;
      row-gap: 8px;
      padding: 0.75em 0;
    }
    .nav-links {
      width: 100%;
      justify-content: flex-start;
      gap: 16px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .nav-links a {
      white-space: nowrap;
    }
  }
</style>
