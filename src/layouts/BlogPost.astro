---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.post-header {
				width: 100%;
				min-height: 280px;
				background: linear-gradient(135deg, #f0f7f5 0%, #c8e0da 100%);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 3rem 2rem;
				box-sizing: border-box;
				text-align: center;
				margin-bottom: 2rem;
			}
			.post-header-inner {
				text-align: center;
				max-width: 720px;
			}
			.category-tag {
				display: inline-block;
				color: #ff6b6b;
				font-size: 0.8em;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.75em;
			}
			.post-header h1 {
				color: #2d9e88;
				font-size: 2.2em;
				line-height: 1.2;
				margin: 0 0 0.5em 0;
			}
			.post-header .date {
				color: #4a7a72;
				font-size: 0.95em;
			}
			.last-updated-on {
				font-style: italic;
				margin-top: 0.25em;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
				color: #1a3a34;
				line-height: 1.8;
			}
			.prose :global(h2) {
				color: #1a3a34;
				border-left: 3px solid #f0a500;
				padding-left: 0.75em;
				margin-top: 2em;
			}
			.prose :global(blockquote) {
				border-left: 3px solid #f0a500;
				padding-left: 1em;
				margin-left: 0;
				color: #1a3a34;
				font-style: italic;
			}
			.back-link {
				display: block;
				margin-top: 3em;
				color: #2d9e88;
				text-decoration: none;
				font-weight: 600;
			}
			.back-link:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="post-header">
					<div class="post-header-inner">
						{category && <span class="category-tag">{category}</span>}
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<div class="last-updated-on">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)}
						</div>
					</div>
				</div>
				<div class="prose">
					<slot />
					<a class="back-link" href="/blog">&larr; Back to Blog</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
