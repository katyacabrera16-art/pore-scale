// Returns a claim's content field in the current language, falling back
// to English if a Spanish field is somehow missing — never show a blank.
function cc(c, field){
  if(currentLang === 'es' && c.es && c.es[field] !== undefined) return c.es[field];
  return c[field];
}

// A claim is only "checkable" toward a real verdict if it has a
// contradiction-mode ingredient check. Informational-only checks (like
// Unscented's fragrance note) don't drive the headline evidence state —
// they're bonus context, not a verifiable claim.
function isCheckable(c){
  return !!(c.redFlagCheck && c.redFlagCheck.mode === 'contradiction');
}

function getEvidenceState(c, ingredientChecked, hits){
  const t = EVIDENCE_STATES_I18N[currentLang];
  if(!isCheckable(c)) return {state:'cannot-verify', cls:'amber', ...t.cannotVerify};
  if(!ingredientChecked) return {state:'not-enough-info', cls:'neutral', ...t.notEnough};
  if(hits.length) return {state:'contradiction', cls:'coral', ...t.contradiction};
  return {state:'supported', cls:'sage', ...t.supported};
}

// Confidence reflects the quality of THIS scan, not just the claim type:
//  - Low: missing information (nothing checked yet) or external evidence
//    required (not checkable from ingredients at all).
//  - Medium: checked, but the ingredient text was sparse/hard to read, or
//    a match only lined up through the OCR-fuzzy fallback (ambiguous
//    terminology / a possible misread rather than a clean, exact match).
//  - High: complete, readable ingredient text and a narrowly verifiable
//    claim, matched exactly.
function getConfidence(c, ingredientChecked, quality){
  if(!isCheckable(c) || !ingredientChecked) return 'Low';
  if(quality === 'medium') return 'Medium';
  return c.verificationMethod === 'ingredient-list check' ? 'High' : 'Medium';
}

const STAMP_CLASS = {'contradiction':'st-contradiction', 'supported':'st-supported', 'cannot-verify':'st-cannotverify', 'not-enough-info':'st-open'};
const STAMP_KEY = {'contradiction':'stampContradiction', 'supported':'stampSupported', 'cannot-verify':'stampCannotVerify', 'not-enough-info':'stampOpenCase'};

function cardHTML(c, idx){
  const S = STRINGS[currentLang];
  const checkResult = ingredientCheckResults[idx];
  const hits = checkResult ? checkResult.hits : [];
  const es = getEvidenceState(c, !!checkResult, hits);
  const confidence = CONFIDENCE_I18N[currentLang][getConfidence(c, !!checkResult, checkResult && checkResult.quality)];
  const name = cc(c, 'name');

  let evidenceDetail = '';
  if(es.state === 'contradiction'){
    evidenceDetail = `<div class="section catch"><h3>${S.whatWeFound}</h3><p>${currentLang==='es' ? 'Detectamos' : 'We detected'} <strong>${hits.join(', ')}</strong> ${S.foundInIngredients} "${name}" ${S.claimOnBottle}</p></div>`;
  }

  let fragranceNote = '';
  if(c.redFlagCheck && c.redFlagCheck.mode === 'info' && checkResult){
    fragranceNote = hits.length
      ? `<div class="fragrance-note"><strong>${S.goodToKnow}:</strong> ${currentLang==='es' ? 'esta lista de ingredientes sí incluye' : 'this ingredient list does include'} ${hits.join(', ')} ${S.commonEvenUnscented}</div>`
      : `<div class="fragrance-note">${S.didntSpotFragrance}</div>`;
  }

  const ingCta = (isCheckable(c) && !checkResult)
    ? `<div class="ing-cta">${S.provideIngredients}</div>` : '';

  const questionsHTML = (cc(c, 'questionsForBrand') || []).map(q=>`<li>${q}</li>`).join('');
  const stampClass = STAMP_CLASS[es.state];
  const stampText = S[STAMP_KEY[es.state]];

  return `
    <div class="case-card" id="card-${idx}">
      <div class="stamp-wrap">
        <div class="stamp ${stampClass}">${stampText}</div>
      </div>
      <div class="case-claim-name">${name}</div>
      <div class="case-sub">${es.sub}</div>
      <button class="see-evidence-btn" onclick="toggleEvidence('${idx}')" id="evBtn-${idx}">${S.seeEvidence}</button>

      <div class="evidence-body" id="evBody-${idx}">
        <span class="badge ${c.tier}">${TIER_LABEL[currentLang][c.tier]}</span>
        <p class="verdict">${cc(c, 'verdict')}</p>
        <div class="section"><h3>${S.whatItMeans}</h3><p>${cc(c, 'meaning')}</p></div>
        <div class="section catch"><h3>${S.theCatch}</h3><p>${cc(c, 'theCatch')}</p></div>
        ${evidenceDetail}
        ${fragranceNote}
        <div class="section"><h3>${S.cannotEstablishHdr}</h3><p>${cc(c, 'cannotEstablish')}</p></div>
        <div class="section"><h3>${S.additionalEvidenceHdr}</h3><p>${cc(c, 'additionalEvidence')}</p></div>
        <div class="section lookfor"><h3>${S.lookFor}</h3><p>${cc(c, 'lookFor')}</p></div>
        ${questionsHTML ? `<div class="section"><h3>${S.questionsHdr}</h3><ul>${questionsHTML}</ul></div>` : ''}
        <div class="section"><h3>${S.limitationsHdr}</h3><p>${cc(c, 'limitations')}</p></div>
        ${ingCta}
        <div class="card-footer">
          <div style="width:100%; margin-bottom:6px;">
            <span>${S.verificationMethod} ${VERIFICATION_LABELS_I18N[currentLang][c.verificationMethod] || c.verificationMethod}</span>
            <span>·</span><span>${S.confidence} ${confidence}</span>
            <span>·</span><span>${S.lastReviewed} ${c.lastReviewed}</span>
          </div>
        <div class="confidence-note">${S.confidenceNote}</div>
      </div>
      <p class="source">${S.source} <a href="${c.sourceUrl}" target="_blank" rel="noopener noreferrer">${c.source}</a></p>
      </div>
    </div>
  `;
}

