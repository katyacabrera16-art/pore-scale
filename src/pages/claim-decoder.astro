// Strips accents properly (é→e, ñ→n) instead of deleting the character
// entirely, which was the bug: "hipoalergénico" was becoming
// "hipoalerg nico" (character gone) rather than "hipoalergenico"
// (accent gone). This matters for every Spanish-language alias.
function normalizeText(str){
  return str.normalize('NFD').replace(/\p{Mn}/gu,'').toLowerCase().replace(/[^a-z0-9\s%-]/g,' ').replace(/\s+/g,' ').trim();
}

// Targets specific, common OCR misreads (0/o, 1/l, 5/s, 8/b) — NOT a
// general typo corrector. A broader fuzzy/edit-distance matcher risks
// false positives (matching things that aren't actually there), which
// is worse than missing a real OCR error. This stays narrow on purpose.
function ocrFuzzyVariant(str){
  return str.replace(/0/g,'o').replace(/1/g,'l').replace(/5/g,'s').replace(/8/g,'b');
}

// Returns 'exact' | 'fuzzy' | null instead of a plain boolean: a match
// that only worked via the OCR-digit fallback means the underlying text
// was ambiguous, which matters for confidence scoring (an ingredient
// check built on a shaky read should never come back "High confidence")
// even though it still counts as a match for display purposes. The
// single place alias matching happens — used everywhere so exact-match
// and fuzzy-match behavior stays consistent across search, claim
// analysis, and ingredient checks.
function matchQuality(normalizedText, alias){
  const na = normalizeText(alias);
  if(normalizedText.includes(na)) return 'exact';
  // Always try the fuzzy fallback too — the OCR misread (a digit standing
  // in for a letter) happens in the SCANNED text, not in our stored,
  // correctly-spelled alias, so gating on the alias alone would miss
  // exactly the cases this exists to catch.
  if(ocrFuzzyVariant(normalizedText).includes(ocrFuzzyVariant(na))) return 'fuzzy';
  return null;
}
function matchesAlias(normalizedText, alias){
  return matchQuality(normalizedText, alias) !== null;
}

