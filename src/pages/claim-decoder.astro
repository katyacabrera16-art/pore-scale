/* ---------- SCAN STEP 1: the claim ---------- */
// (matchedClaims, ingredientCheckResults, inputMode, lastClaimSource are
// declared near the top of this script — see note there.)

// Shared analysis logic — used by BOTH the scan flow (after OCR) and the
// typed/pasted flow. This is the core Stage 1 principle: the *source* of
// the text (photo vs. keyboard) shouldn't change how it gets evaluated.
function runInvestigation(onComplete){
  const S = STRINGS[currentLang];
  const lines = [S.investigating1, S.investigating2, S.investigating3, S.investigating4];
  const container = document.getElementById('scanResults');
  container.innerHTML = `<div class="investigating"><div class="magnifier">🔎</div><div class="inv-line" id="invLine"></div></div>`;
  const lineEl = document.getElementById('invLine');
  let i = 0;
  function nextLine(){
    if(i < lines.length){
      lineEl.style.animation = 'none'; void lineEl.offsetHeight; lineEl.style.animation = null;
      lineEl.innerHTML = lines[i] + ' <span class="inv-dots"><span></span><span></span><span></span></span>';
      i++;
      setTimeout(nextLine, 550);
    } else {
      setTimeout(onComplete, 300);
    }
  }
  nextLine();
}

function analyzeClaimText(rawText){
  const S = STRINGS[currentLang];
  const normalized = normalizeText(rawText);
  document.getElementById('claimMatchConfirm').style.display = 'none';

  if(!normalized){
    document.getElementById('scanResults').innerHTML = `<div class="scan-empty">${S.noTextYet}</div>`;
    document.getElementById('ingPromptWrap').innerHTML = '';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'none';
    return;
  }

  matchedClaims = [];
  ingredientCheckResults = {};
  CLAIMS.forEach((c,i)=>{
    if(c.aliases.some(a => matchesAlias(normalized, a))) matchedClaims.push(i);
  });

  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('typeStep2').style.display = 'none';

  if(matchedClaims.length){
    runInvestigation(() => {
      document.getElementById('scanResults').innerHTML = matchedClaims.map(i=>cardHTML(CLAIMS[i], i)).join('');
      const needsIngredientCheck = matchedClaims.filter(i=>CLAIMS[i].redFlagCheck);
      if(needsIngredientCheck.length){
        const names = needsIngredientCheck.map(i=>cc(CLAIMS[i],'name')).join(', ');
        const howTo = lastClaimSource === 'scan' ? S.scanIngredientNext : S.pasteIngredientNext;
        document.getElementById('ingPromptWrap').innerHTML = `
          <div class="ing-prompt">
            <p>${S.wantToKnow} <span class="claim-list">${names}</span>? ${howTo}</p>
          </div>`;
        if(lastClaimSource === 'scan'){ document.getElementById('step2').style.display = 'block'; }
        else { document.getElementById('typeStep2').style.display = 'block'; }
      }
    });
  } else {
    document.getElementById('scanResults').innerHTML = `<div class="scan-empty">${S.scanClaimNoMatch}</div>`;
  }
}

function analyzeIngredientText(rawText){
  const normalized = normalizeText(rawText);
  if(!normalized) return;

  // Confidence input: is this ingredient text actually substantial, or
  // short/sparse in a way that suggests a partial scan or a rushed paste?
  // A real INCI list is usually a long comma-separated run of words —
  // under ~40 letters is a strong sign of incomplete information, which
  // caps confidence at Medium even if every claim matches cleanly.
  const textIsSparse = normalized.replace(/[^a-z]/g,'').length < 40;

  matchedClaims.forEach(i=>{
    const c = CLAIMS[i];
    if(!c.redFlagCheck) return;
    // Track whether ANY alias for ANY of this claim's flagged ingredients
    // only lined up via the OCR-fuzzy fallback — that's "possible
    // ingredient synonyms / ambiguous terminology" territory, which caps
    // confidence at Medium per claim even when hits themselves are real.
    let anyFuzzy = false;
    const hits = c.redFlagCheck.ingredients
      .filter(ing => ing.aliases.some(a => {
        const q = matchQuality(normalized, a);
        if(q === 'fuzzy') anyFuzzy = true;
        return q !== null;
      }))
      .map(ing => ing.name);
    ingredientCheckResults[i] = {
      checked:true,
      hits,
      quality: (textIsSparse || anyFuzzy) ? 'medium' : 'high'
    };
  });

  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('typeStep2').style.display = 'none';

  // Re-run the investigation beat before revealing the updated stamps —
  // this is the actual payoff moment (open case → real verdict), so it
  // deserves the same build-up as the first reveal, not an instant swap.
  runInvestigation(() => {
    document.getElementById('scanResults').innerHTML = matchedClaims.map(i=>cardHTML(CLAIMS[i], i)).join('');
  });
}

const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB — generous for a phone photo, protects against accidental huge uploads

function wireDropzone(zoneId, inputId, previewSectionId, previewImgId){
  const zone = document.getElementById(zoneId);
  const input = document.getElementById(inputId);
  zone.addEventListener('click', ()=>input.click());
  zone.addEventListener('keydown', e=>{
    if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); input.click(); }
  });
  zone.addEventListener('dragover', e=>{e.preventDefault(); zone.classList.add('dragover');});
  zone.addEventListener('dragleave', ()=>zone.classList.remove('dragover'));
  zone.addEventListener('drop', e=>{
    e.preventDefault(); zone.classList.remove('dragover');
    if(e.dataTransfer.files[0]) validateAndLoad(e.dataTransfer.files[0], zoneId, previewSectionId, previewImgId);
  });
  input.addEventListener('change', ()=>{ if(input.files[0]) validateAndLoad(input.files[0], zoneId, previewSectionId, previewImgId); });
}

function validateAndLoad(file, zoneId, previewSectionId, previewImgId){
  const S = STRINGS[currentLang];
  const zone = document.getElementById(zoneId);
  const existingError = zone.querySelector('.file-error');
  if(existingError) existingError.remove();

  if(!file.type.startsWith('image/')){
    const err = document.createElement('p');
    err.className = 'file-error';
    err.textContent = `${currentLang==='es' ? 'Eso es' : "That's a"} ${file.type || S.unrecognizedType} ${S.fileTypeError}`;
    zone.appendChild(err);
    return;
  }
  if(file.size > MAX_FILE_SIZE){
    const err = document.createElement('p');
    err.className = 'file-error';
    err.textContent = `${S.fileSizeError1} ${(file.size / (1024*1024)).toFixed(1)}${S.fileSizeError2}`;
    zone.appendChild(err);
    return;
  }
  loadPreview(file, zoneId, previewSectionId, previewImgId);
}

function loadPreview(file, zoneId, previewSectionId, previewImgId){
  document.getElementById(previewImgId).src = URL.createObjectURL(file);
  document.getElementById(zoneId).style.display='none';
  document.getElementById(previewSectionId).style.display='block';
}

// Preprocesses a photo before handing it to the text reader: converts to
// grayscale, then binarizes to pure black/white using Otsu's method
// (computes the ideal cutoff from the image's own brightness histogram,
// rather than a guessed fixed value). Tesseract reads clean black-on-
// white far more reliably than a raw color photo with glare, shadows, or
// a busy background. NOTE: the uploaded "Case File" prototype export
// didn't actually contain the grayscale/contrast/resize preprocessing it
// was described as having — this keeps the working, already-tested
// preprocessing from the previous build instead of dropping it. Flagged
// to Katya; easy to swap for a different approach if she wants one.
function preprocessImageForOCR(imgEl){
  const canvas = document.createElement('canvas');
  canvas.width = imgEl.naturalWidth;
  canvas.height = imgEl.naturalHeight;
  const ctx = canvas.getContext('2d');
  ctx.drawImage(imgEl, 0, 0);
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
  const data = imageData.data;

  // Grayscale (luminance-weighted) + a 256-bin brightness histogram, built in one pass
  const hist = new Array(256).fill(0);
  const gray = new Uint8ClampedArray(data.length / 4);
  for(let i=0, p=0; i<data.length; i+=4, p++){
    const g = Math.round(0.299*data[i] + 0.587*data[i+1] + 0.114*data[i+2]);
    gray[p] = g;
    hist[g]++;
  }

  // Otsu's method: the threshold that maximizes contrast between the
  // "dark" and "light" groups of pixels — this is what adapts to each
  // photo's own lighting instead of a one-size-fits-all cutoff.
  const total = gray.length;
  let sum = 0;
  for(let t=0; t<256; t++) sum += t * hist[t];
  let sumB = 0, wB = 0, maxVar = 0, threshold = 127;
  for(let t=0; t<256; t++){
    wB += hist[t];
    if(wB === 0) continue;
    const wF = total - wB;
    if(wF === 0) break;
    sumB += t * hist[t];
    const mB = sumB / wB;
    const mF = (sum - sumB) / wF;
    const varBetween = wB * wF * (mB - mF) * (mB - mF);
    if(varBetween > maxVar){ maxVar = varBetween; threshold = t; }
  }

  for(let i=0, p=0; i<data.length; i+=4, p++){
    const v = gray[p] > threshold ? 255 : 0;
    data[i] = data[i+1] = data[i+2] = v;
  }
  ctx.putImageData(imageData, 0, 0);
  return canvas.toDataURL('image/png');
}

