document.getElementById('decodeBtn1').addEventListener('click', async ()=>{
  const S = STRINGS[currentLang];
  const btn = document.getElementById('decodeBtn1');
  const status = document.getElementById('scanStatus1');
  btn.disabled = true;
  document.getElementById('scanLine1').classList.add('active');
  status.classList.add('active');
  document.getElementById('scanStatusText1').textContent = S.readingLabel;
  document.getElementById('scanResults').innerHTML = '';
  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('claimMatchConfirm').style.display = 'none';

  try{
    const preprocessed = preprocessImageForOCR(document.getElementById('previewImg1'));
    const { data: { text } } = await Tesseract.recognize(preprocessed, 'eng');
    const cleaned = text.trim();
    const claimBox = document.getElementById('claimTextInput');
    const hint = document.getElementById('claimTextHint');
    claimBox.value = cleaned;
    lastClaimSource = 'scan';

    // Pill-confirmation flow: match the scanned text against the glossary
    // FIRST, and only surface it as matched claim pills — raw OCR text is
    // no longer the primary thing shown after a scan. It's still there as
    // a fallback (no match found) or via the explicit "Edit the text
    // instead" link, so a bad scan is never a dead end.
    const normalized = normalizeText(cleaned);
    const foundIdx = [];
    CLAIMS.forEach((c,i)=>{ if(c.aliases.some(a => matchesAlias(normalized, a))) foundIdx.push(i); });

    if(foundIdx.length){
      showClaimMatchConfirm(foundIdx, cleaned);
    } else {
      setInputMode('type');
      hint.textContent = cleaned.replace(/[^a-zA-Z]/g,'').length < 4 ? S.couldntReadClaim : S.noGlossaryMatchPhoto;
      claimBox.focus();
    }
  } catch(err){
    setInputMode('type');
    document.getElementById('claimTextHint').textContent = S.somethingWrongClaim;
  } finally {
    document.getElementById('scanLine1').classList.remove('active');
    status.classList.remove('active');
    btn.disabled = false;
  }
});

// Renders the "we found this on the label" pill-confirmation card after a
// successful claim scan. Confirming re-runs the same analyzeClaimText()
// path the typed-input flow uses (source of the text shouldn't change how
// it's evaluated); "Edit the text instead" drops into the raw-text box
// with the OCR result pre-filled, for anyone who wants to fix a misread.
function showClaimMatchConfirm(foundIdx, rawText){
  const S = STRINGS[currentLang];
  document.getElementById('typeInputPanel').style.display = 'none';
  const wrap = document.getElementById('claimMatchConfirm');
  const pills = foundIdx.map(i => `<span class="match-pill">${cc(CLAIMS[i],'name')}</span>`).join('');
  wrap.innerHTML = `
    <div class="match-confirm">
      <p>${S.weFoundClaims}</p>
      <div class="match-pills">${pills}</div>
      <div class="confirm-actions">
        <button class="btn btn-primary" id="confirmClaimBtn">${S.confirmDecode}</button>
      </div>
      <div style="margin-top:12px;"><button class="edit-text-link" id="editClaimTextBtn">${S.editTextInstead}</button></div>
    </div>`;
  wrap.style.display = 'block';
  document.getElementById('confirmClaimBtn').addEventListener('click', ()=> analyzeClaimText(rawText));
  document.getElementById('editClaimTextBtn').addEventListener('click', ()=>{
    wrap.style.display = 'none';
    setInputMode('type');
    document.getElementById('claimTextInput').focus();
  });
}

/* ---------- TYPED CLAIM INPUT ---------- */
document.getElementById('analyzeClaimBtn').addEventListener('click', ()=>{
  const val = document.getElementById('claimTextInput').value;
  const hint = document.getElementById('claimTextHint');
  if(!val.trim()){
    hint.textContent = STRINGS[currentLang].typeSomethingFirst;
    return;
  }
  hint.textContent = '';
  analyzeClaimText(val);
});

/* ---------- SCAN STEP 2: the ingredients ---------- */
document.getElementById('decodeBtn2').addEventListener('click', async ()=>{
  const S = STRINGS[currentLang];
  const btn = document.getElementById('decodeBtn2');
  const status = document.getElementById('scanStatus2');
  btn.disabled = true;
  document.getElementById('scanLine2').classList.add('active');
  status.classList.add('active');
  document.getElementById('scanStatusText2').textContent = S.readingIngredients;
  document.getElementById('ingMatchConfirm').style.display = 'none';

  try{
    const preprocessed = preprocessImageForOCR(document.getElementById('previewImg2'));
    const { data: { text } } = await Tesseract.recognize(preprocessed, 'eng');
    const cleaned = text.trim();
    const ingBox = document.getElementById('ingredientTextInput');
    ingBox.value = cleaned;

    if(cleaned.replace(/[^a-zA-Z]/g,'').length < 4){
      document.getElementById('step2').style.display = 'none';
      document.getElementById('typeStep2').style.display = 'block';
      document.getElementById('ingredientTextHint').textContent = S.couldntReadIng;
      ingBox.focus();
    } else {
      showIngredientMatchConfirm(cleaned);
    }
  } catch(err){
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'block';
    document.getElementById('ingredientTextHint').textContent = S.somethingWrongIng;
  } finally {
    document.getElementById('scanLine2').classList.remove('active');
    status.classList.remove('active');
    btn.disabled = false;
  }
});

// Same pill-confirmation pattern as the claim step: shows which of the
// currently-matched claims' flagged ingredients turned up in this scan
// (or an honest "none found" if the list is clean), before running the
// actual ingredient check.
function showIngredientMatchConfirm(rawText){
  const S = STRINGS[currentLang];
  const normalized = normalizeText(rawText);
  document.getElementById('step2').style.display = 'none';
  document.getElementById('typeStep2').style.display = 'none';

  const foundNames = [];
  matchedClaims.forEach(i=>{
    const c = CLAIMS[i];
    if(!c.redFlagCheck) return;
    c.redFlagCheck.ingredients.forEach(ing=>{
      if(ing.aliases.some(a=>matchesAlias(normalized, a)) && !foundNames.includes(ing.name)) foundNames.push(ing.name);
    });
  });

  const wrap = document.getElementById('ingMatchConfirm');
  const pillsOrNone = foundNames.length
    ? foundNames.map(n=>`<span class="match-pill">${n}</span>`).join('')
    : `<p style="margin:0; font-style:italic; color:var(--ink-soft);">${S.noneOfTheseFound}</p>`;
  wrap.innerHTML = `
    <div class="match-confirm">
      <p>${S.weFoundIngredients}</p>
      <div class="match-pills">${pillsOrNone}</div>
      <div class="confirm-actions">
        <button class="btn btn-sage" id="confirmIngBtn">${S.confirmDecode}</button>
      </div>
      <div style="margin-top:12px;"><button class="edit-text-link" id="editIngTextBtn">${S.editTextInstead}</button></div>
    </div>`;
  wrap.style.display = 'block';
  document.getElementById('confirmIngBtn').addEventListener('click', ()=> analyzeIngredientText(rawText));
  document.getElementById('editIngTextBtn').addEventListener('click', ()=>{
    wrap.style.display = 'none';
    document.getElementById('typeStep2').style.display = 'block';
    document.getElementById('ingredientTextInput').focus();
  });
}

/* ---------- TYPED INGREDIENT INPUT ---------- */
document.getElementById('analyzeIngredientsBtn').addEventListener('click', ()=>{
  const val = document.getElementById('ingredientTextInput').value;
  const hint = document.getElementById('ingredientTextHint');
  if(!val.trim()){
    hint.textContent = STRINGS[currentLang].pasteSomethingFirst;
    return;
  }
  hint.textContent = '';
  analyzeIngredientText(val);
  document.getElementById('scanResults').scrollIntoView({behavior:'smooth', block:'start'});
});

/* ---------- INPUT MODE TOGGLE (scan vs. type) ---------- */
function setInputMode(mode){
  inputMode = mode;
  document.querySelectorAll('.input-toggle-btn').forEach(b=>b.classList.toggle('active', b.dataset.input === mode));
  document.getElementById('scanInputPanel').style.display = mode === 'scan' ? 'block' : 'none';
  document.getElementById('typeInputPanel').style.display = mode === 'type' ? 'block' : 'none';
}

document.querySelectorAll('.input-toggle-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    setInputMode(btn.dataset.input);
    lastClaimSource = btn.dataset.input;
    document.getElementById('scanResults').innerHTML = '';
    document.getElementById('ingPromptWrap').innerHTML = '';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'none';
  });
});

document.getElementById('termsToggle').addEventListener('click', ()=>{
  const el = document.getElementById('termsFull');
  const btn = document.getElementById('termsToggle');
  const open = el.classList.toggle('open');
  const S = STRINGS[currentLang];
  btn.textContent = open ? S.termsToggleOpen : S.termsToggle;
});
</script>
</body>
</html>
