function applyLanguage(lang){
  currentLang = lang;
  document.documentElement.lang = lang;
  document.getElementById('langBtnEn').classList.toggle('active', lang==='en');
  document.getElementById('langBtnEs').classList.toggle('active', lang==='es');

  document.querySelectorAll('[data-i18n]').forEach(el=>{
    const key = el.dataset.i18n;
    const val = STRINGS[lang][key];
    if(val === undefined) return;
    if(key === 'disclaimerMain' || key === 'privacyLine' || key === 'termsFullInner'){
      el.innerHTML = val;
    } else {
      el.textContent = val;
    }
  });
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el=>{
    const key = el.dataset.i18nPlaceholder;
    if(STRINGS[lang][key] !== undefined) el.placeholder = STRINGS[lang][key];
  });

  const termsBtn = document.getElementById('termsToggle');
  const isOpen = document.getElementById('termsFull').classList.contains('open');
  termsBtn.textContent = isOpen ? STRINGS[lang].termsToggleOpen : STRINGS[lang].termsToggle;

  // Re-render dynamic content (chips + any visible cards) in the new language
  renderChips();
  if(resultEl.classList.contains('show')){
    const activeChip = document.querySelector('.chip.active');
    if(activeChip) renderCard(CLAIMS[Number(activeChip.dataset.index)]);
  }
  if(matchedClaims.length){
    document.getElementById('scanResults').innerHTML = matchedClaims.map(i=>cardHTML(CLAIMS[i], i)).join('');
  }
}

document.getElementById('langBtnEn').addEventListener('click', ()=>applyLanguage('en'));
document.getElementById('langBtnEs').addEventListener('click', ()=>applyLanguage('es'));

// Strips accents properly (é→e, ñ→n) instead of deleting the character
// entirely, which was the bug: "hipoalergénico" was becoming
// "hipoalerg nico" (character gone) rather than "hipoalergenico"
// (accent gone). This matters for every Spanish-language alias.
function normalizeText(str){
  return str.normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase().replace(/[^a-z0-9\s%-]/g,' ').replace(/\s+/g,' ').trim();
}

// Targets specific, common OCR misreads (0/o, 1/l, 5/s, 8/b) — NOT a
// general typo corrector. A broader fuzzy/edit-distance matcher risks
// false positives (matching things that aren't actually there), which
// is worse than missing a real OCR error. This stays narrow on purpose.
function ocrFuzzyVariant(str){
  return str.replace(/0/g,'o').replace(/1/g,'l').replace(/5/g,'s').replace(/8/g,'b');
}

// The single place alias matching happens — used everywhere so the
// exact-match and fuzzy-match behavior stays consistent across search,
// claim analysis, and ingredient checks.
function matchesAlias(normalizedText, alias){
  const na = normalizeText(alias);
  if(normalizedText.includes(na)) return true;
  // Always try the fuzzy fallback too — the OCR misread (a digit standing
  // in for a letter) happens in the SCANNED text, not in our stored,
  // correctly-spelled alias, so gating on the alias alone would miss
  // exactly the cases this exists to catch.
  return ocrFuzzyVariant(normalizedText).includes(ocrFuzzyVariant(na));
}

const chipContainer = document.getElementById('chipContainer');
const resultEl = document.getElementById('result');
const emptyEl = document.getElementById('emptyState');
const searchInput = document.getElementById('searchInput');

function renderChips(){
  chipContainer.innerHTML = '';
  CLAIMS.forEach((c,i)=>{
    const chip = document.createElement('button');
    chip.className='chip';
    chip.textContent = (currentLang === 'es' && c.es) ? c.es.name : c.name;
    chip.dataset.index=i;
    chip.addEventListener('click',()=>{ chip.classList.add('pressed'); setTimeout(()=>chip.classList.remove('pressed'),280); selectClaim(i); });
    chipContainer.appendChild(chip);
  });
}
renderChips();

// Returns a claim's content field in the current language, falling back
// to English if a Spanish field is somehow missing — never show a blank.
function cc(c, field){
  if(currentLang === 'es' && c.es && c.es[field] !== undefined) return c.es[field];
  return c[field];
}

// A claim is only "checkable" toward a real verdict if it has a
// contradiction-mode ingredient check. Informational-only checks (like
// Unscented's fragrance note) don't drive the headline evidence state —
// they're bonus context, not a verifiable claim.
function isCheckable(c){
  return !!(c.redFlagCheck && c.redFlagCheck.mode === 'contradiction');
}

function getEvidenceState(c, ingredientChecked, hits){
  const t = EVIDENCE_STATES_I18N[currentLang];
  if(!isCheckable(c)) return {state:'cannot-verify', cls:'amber', ...t.cannotVerify};
  if(!ingredientChecked) return {state:'not-enough-info', cls:'neutral', ...t.notEnough};
  if(hits.length) return {state:'contradiction', cls:'coral', ...t.contradiction};
  return {state:'supported', cls:'sage', ...t.supported};
}

function getConfidence(c, ingredientChecked){
  if(!isCheckable(c) || !ingredientChecked) return 'Low';
  return c.verificationMethod === 'ingredient-list check' ? 'High' : 'Medium';
}

function cardHTML(c, idx){
  const S = STRINGS[currentLang];
  const checkResult = ingredientCheckResults[idx];
  const hits = checkResult ? checkResult.hits : [];
  const es = getEvidenceState(c, !!checkResult, hits);
  const confidence = CONFIDENCE_I18N[currentLang][getConfidence(c, !!checkResult)];
  const name = cc(c, 'name');

  let evidenceDetail = '';
  if(es.state === 'contradiction'){
    evidenceDetail = `<div class="section catch"><h3>${S.whatWeFound}</h3><p>${currentLang==='es' ? 'Detectamos' : 'We detected'} <strong>${hits.join(', ')}</strong> ${S.foundInIngredients} "${name}" ${S.claimOnBottle}</p></div>`;
  }

  let fragranceNote = '';
  if(c.redFlagCheck && c.redFlagCheck.mode === 'info' && checkResult){
    fragranceNote = hits.length
      ? `<div class="fragrance-note"><strong>${S.goodToKnow}:</strong> ${currentLang==='es' ? 'esta lista de ingredientes sí incluye' : 'this ingredient list does include'} ${hits.join(', ')} ${S.commonEvenUnscented}</div>`
      : `<div class="fragrance-note">${S.didntSpotFragrance}</div>`;
  }

  const ingCta = (isCheckable(c) && !checkResult)
    ? `<div class="ing-cta">${S.provideIngredients}</div>` : '';

  const questionsHTML = (cc(c, 'questionsForBrand') || []).map(q=>`<li>${q}</li>`).join('');

  return `
    <div class="card" id="card-${idx}">
      <div class="evidence-banner ${es.cls}">
        <span class="evidence-icon">${es.icon}</span>
        <div>
          <div class="evidence-label">${es.label}</div>
          <div class="evidence-sub">${es.sub}</div>
        </div>
      </div>
      <span class="badge ${c.tier}">${TIER_LABEL[currentLang][c.tier]}</span>
      <h2>${name}</h2>
      <p class="verdict">${cc(c, 'verdict')}</p>
      <div class="section"><h3>${S.whatItMeans}</h3><p>${cc(c, 'meaning')}</p></div>
      <div class="section catch"><h3>${S.theCatch}</h3><p>${cc(c, 'theCatch')}</p></div>
      ${evidenceDetail}
      ${fragranceNote}
      <div class="section"><h3>${S.cannotEstablishHdr}</h3><p>${cc(c, 'cannotEstablish')}</p></div>
      <div class="section"><h3>${S.additionalEvidenceHdr}</h3><p>${cc(c, 'additionalEvidence')}</p></div>
      <div class="section lookfor"><h3>${S.lookFor}</h3><p>${cc(c, 'lookFor')}</p></div>
      ${questionsHTML ? `<div class="section"><h3>${S.questionsHdr}</h3><ul>${questionsHTML}</ul></div>` : ''}
      <div class="section"><h3>${S.limitationsHdr}</h3><p>${cc(c, 'limitations')}</p></div>
      ${ingCta}
      <div class="card-footer">
        <div style="width:100%; margin-bottom:6px;">
          <span>${S.verificationMethod} ${VERIFICATION_LABELS_I18N[currentLang][c.verificationMethod] || c.verificationMethod}</span>
          <span>·</span><span>${S.confidence} ${confidence}</span>
          <span>·</span><span>${S.lastReviewed} ${c.lastReviewed}</span>
        </div>
        <div class="confidence-note">${S.confidenceNote}</div>
      </div>
      <p class="source">${S.source} <a href="${c.sourceUrl}" target="_blank" rel="noopener noreferrer">${c.source}</a></p>
    </div>
  `;
}


function renderCard(c){
  resultEl.innerHTML = cardHTML(c, 'search');
  resultEl.classList.add('show');
  emptyEl.style.display='none';
}

function selectClaim(i){
  document.querySelectorAll('.chip').forEach(el=>el.classList.remove('active'));
  const chip = chipContainer.querySelector(`[data-index="${i}"]`);
  if(chip) chip.classList.add('active');
  renderCard(CLAIMS[i]);
  resultEl.scrollIntoView({behavior:'smooth', block:'nearest'});
}

searchInput.addEventListener('input', ()=>{
  const q = searchInput.value.trim().toLowerCase();
  let anyVisible = false;
  document.querySelectorAll('.chip').forEach((chip,i)=>{
    const c = CLAIMS[i];
    const match = !q || normalizeText(cc(c,'name')).includes(normalizeText(q)) || c.aliases.some(a=>normalizeText(a).includes(normalizeText(q)));
    chip.classList.toggle('hidden', !match);
    if(match) anyVisible = true;
  });
  emptyEl.style.display = (!anyVisible && q) ? 'block' : 'none';
});
searchInput.addEventListener('keydown', (e)=>{
  if(e.key==='Enter'){
    const q = searchInput.value.trim().toLowerCase();
    const idx = CLAIMS.findIndex(c=>normalizeText(cc(c,'name')).includes(normalizeText(q)) || c.aliases.some(a=>normalizeText(a).includes(normalizeText(q))));
    if(idx>-1) selectClaim(idx);
  }
});
selectClaim(0);

document.querySelectorAll('.mode-tab').forEach(tab=>{
  tab.addEventListener('click', ()=>{
    document.querySelectorAll('.mode-tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    const mode = tab.dataset.mode;
    document.getElementById('searchPanel').classList.toggle('active', mode==='search');
    document.getElementById('scanPanel').classList.toggle('active', mode==='scan');
  });
});

/* ---------- SCAN STEP 1: the claim ---------- */
// (matchedClaims, ingredientCheckResults, inputMode, lastClaimSource are
// declared near the top of this script — see note there.)

// Shared analysis logic — used by BOTH the scan flow (after OCR) and the
// typed/pasted flow. This is the core Stage 1 principle: the *source* of
// the text (photo vs. keyboard) shouldn't change how it gets evaluated.
function analyzeClaimText(rawText){
  const S = STRINGS[currentLang];
  const normalized = normalizeText(rawText);

  if(!normalized){
    document.getElementById('scanResults').innerHTML = `<div class="scan-empty">${S.noTextYet}</div>`;
    document.getElementById('ingPromptWrap').innerHTML = '';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'none';
    return;
  }

  matchedClaims = [];
  ingredientCheckResults = {};
  CLAIMS.forEach((c,i)=>{
    if(c.aliases.some(a => matchesAlias(normalized, a))) matchedClaims.push(i);
  });

  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('typeStep2').style.display = 'none';

  if(matchedClaims.length){
    document.getElementById('scanResults').innerHTML = matchedClaims.map(i=>cardHTML(CLAIMS[i], i)).join('');
    const needsIngredientCheck = matchedClaims.filter(i=>CLAIMS[i].redFlagCheck);
    if(needsIngredientCheck.length){
      const names = needsIngredientCheck.map(i=>cc(CLAIMS[i],'name')).join(', ');
      const howTo = lastClaimSource === 'scan' ? S.scanIngredientNext : S.pasteIngredientNext;
      document.getElementById('ingPromptWrap').innerHTML = `
        <div class="ing-prompt">
          <p>${S.wantToKnow} <span class="claim-list">${names}</span>? ${howTo}</p>
        </div>`;
      if(lastClaimSource === 'scan'){ document.getElementById('step2').style.display = 'block'; }
      else { document.getElementById('typeStep2').style.display = 'block'; }
    }
  } else {
    document.getElementById('scanResults').innerHTML = `<div class="scan-empty">${S.scanClaimNoMatch}</div>`;
  }
}

function analyzeIngredientText(rawText){
  const normalized = normalizeText(rawText);
  if(!normalized) return;

  matchedClaims.forEach(i=>{
    const c = CLAIMS[i];
    if(!c.redFlagCheck) return;
    const hits = c.redFlagCheck.ingredients
      .filter(ing => ing.aliases.some(a => matchesAlias(normalized, a)))
      .map(ing => ing.name);
    ingredientCheckResults[i] = {checked:true, hits};
  });

  // Re-render every matched card so each one's evidence banner reflects
  // the just-completed check — not just the claims that had a hit.
  document.getElementById('scanResults').innerHTML = matchedClaims.map(i=>cardHTML(CLAIMS[i], i)).join('');
  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';
  document.getElementById('typeStep2').style.display = 'none';
}

const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB — generous for a phone photo, protects against accidental huge uploads

function wireDropzone(zoneId, inputId, previewSectionId, previewImgId){
  const zone = document.getElementById(zoneId);
  const input = document.getElementById(inputId);
  zone.addEventListener('click', ()=>input.click());
  zone.addEventListener('keydown', e=>{
    if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); input.click(); }
  });
  zone.addEventListener('dragover', e=>{e.preventDefault(); zone.classList.add('dragover');});
  zone.addEventListener('dragleave', ()=>zone.classList.remove('dragover'));
  zone.addEventListener('drop', e=>{
    e.preventDefault(); zone.classList.remove('dragover');
    if(e.dataTransfer.files[0]) validateAndLoad(e.dataTransfer.files[0], zoneId, previewSectionId, previewImgId);
  });
  input.addEventListener('change', ()=>{ if(input.files[0]) validateAndLoad(input.files[0], zoneId, previewSectionId, previewImgId); });
}

function validateAndLoad(file, zoneId, previewSectionId, previewImgId){
  const S = STRINGS[currentLang];
  const zone = document.getElementById(zoneId);
  const existingError = zone.querySelector('.file-error');
  if(existingError) existingError.remove();

  if(!file.type.startsWith('image/')){
    const err = document.createElement('p');
    err.className = 'file-error';
    err.textContent = `${currentLang==='es' ? 'Eso es' : "That's a"} ${file.type || S.unrecognizedType} ${S.fileTypeError}`;
    zone.appendChild(err);
    return;
  }
  if(file.size > MAX_FILE_SIZE){
    const err = document.createElement('p');
    err.className = 'file-error';
    err.textContent = `${S.fileSizeError1} ${(file.size / (1024*1024)).toFixed(1)}${S.fileSizeError2}`;
    zone.appendChild(err);
    return;
  }
  loadPreview(file, zoneId, previewSectionId, previewImgId);
}

function loadPreview(file, zoneId, previewSectionId, previewImgId){
  document.getElementById(previewImgId).src = URL.createObjectURL(file);
  document.getElementById(zoneId).style.display='none';
  document.getElementById(previewSectionId).style.display='block';
}

wireDropzone('dropzone1','fileInput1','previewSection1','previewImg1');
wireDropzone('dropzone2','fileInput2','previewSection2','previewImg2');

document.getElementById('retakeBtn1').addEventListener('click', ()=>{
  document.getElementById('previewSection1').style.display='none';
  document.getElementById('dropzone1').style.display='block';
  document.getElementById('fileInput1').value='';
});
document.getElementById('retakeBtn2').addEventListener('click', ()=>{
  document.getElementById('previewSection2').style.display='none';
  document.getElementById('dropzone2').style.display='block';
  document.getElementById('fileInput2').value='';
});

document.getElementById('decodeBtn1').addEventListener('click', async ()=>{
  const S = STRINGS[currentLang];
  const btn = document.getElementById('decodeBtn1');
  const status = document.getElementById('scanStatus1');
  btn.disabled = true;
  document.getElementById('scanLine1').classList.add('active');
  status.classList.add('active');
  document.getElementById('scanStatusText1').textContent = S.readingLabel;
  document.getElementById('scanResults').innerHTML = '';
  document.getElementById('ingPromptWrap').innerHTML = '';
  document.getElementById('step2').style.display = 'none';

  try{
    const { data: { text } } = await Tesseract.recognize(document.getElementById('previewImg1').src, 'eng');
    const cleaned = text.trim();
    const claimBox = document.getElementById('claimTextInput');
    const hint = document.getElementById('claimTextHint');
    claimBox.value = cleaned;
    setInputMode('type');
    lastClaimSource = 'scan';
    if(cleaned.replace(/[^a-zA-Z]/g,'').length < 4){
      hint.textContent = S.couldntReadClaim;
    } else {
      hint.textContent = S.hereWhatWeReadClaim;
    }
    claimBox.focus();
  } catch(err){
    setInputMode('type');
    document.getElementById('claimTextHint').textContent = S.somethingWrongClaim;
  } finally {
    document.getElementById('scanLine1').classList.remove('active');
    status.classList.remove('active');
    btn.disabled = false;
  }
});

/* ---------- TYPED CLAIM INPUT ---------- */
document.getElementById('analyzeClaimBtn').addEventListener('click', ()=>{
  const val = document.getElementById('claimTextInput').value;
  const hint = document.getElementById('claimTextHint');
  if(!val.trim()){
    hint.textContent = STRINGS[currentLang].typeSomethingFirst;
    return;
  }
  hint.textContent = '';
  analyzeClaimText(val);
});

/* ---------- SCAN STEP 2: the ingredients ---------- */
document.getElementById('decodeBtn2').addEventListener('click', async ()=>{
  const S = STRINGS[currentLang];
  const btn = document.getElementById('decodeBtn2');
  const status = document.getElementById('scanStatus2');
  btn.disabled = true;
  document.getElementById('scanLine2').classList.add('active');
  status.classList.add('active');
  document.getElementById('scanStatusText2').textContent = S.readingIngredients;

  try{
    const { data: { text } } = await Tesseract.recognize(document.getElementById('previewImg2').src, 'eng');
    const cleaned = text.trim();
    const ingBox = document.getElementById('ingredientTextInput');
    const hint = document.getElementById('ingredientTextHint');
    ingBox.value = cleaned;
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'block';
    if(cleaned.replace(/[^a-zA-Z]/g,'').length < 4){
      hint.textContent = S.couldntReadIng;
    } else {
      hint.textContent = S.hereWhatWeReadIng;
    }
    ingBox.focus();
  } catch(err){
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'block';
    document.getElementById('ingredientTextHint').textContent = S.somethingWrongIng;
  } finally {
    document.getElementById('scanLine2').classList.remove('active');
    status.classList.remove('active');
    btn.disabled = false;
  }
});

/* ---------- TYPED INGREDIENT INPUT ---------- */
document.getElementById('analyzeIngredientsBtn').addEventListener('click', ()=>{
  const val = document.getElementById('ingredientTextInput').value;
  const hint = document.getElementById('ingredientTextHint');
  if(!val.trim()){
    hint.textContent = STRINGS[currentLang].pasteSomethingFirst;
    return;
  }
  hint.textContent = '';
  analyzeIngredientText(val);
  document.getElementById('scanResults').scrollIntoView({behavior:'smooth', block:'start'});
});

/* ---------- INPUT MODE TOGGLE (scan vs. type) ---------- */
function setInputMode(mode){
  inputMode = mode;
  document.querySelectorAll('.input-toggle-btn').forEach(b=>b.classList.toggle('active', b.dataset.input === mode));
  document.getElementById('scanInputPanel').style.display = mode === 'scan' ? 'block' : 'none';
  document.getElementById('typeInputPanel').style.display = mode === 'type' ? 'block' : 'none';
}

document.querySelectorAll('.input-toggle-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    setInputMode(btn.dataset.input);
    lastClaimSource = btn.dataset.input;
    document.getElementById('scanResults').innerHTML = '';
    document.getElementById('ingPromptWrap').innerHTML = '';
    document.getElementById('step2').style.display = 'none';
    document.getElementById('typeStep2').style.display = 'none';
  });
});

document.getElementById('termsToggle').addEventListener('click', ()=>{
  const el = document.getElementById('termsFull');
  const btn = document.getElementById('termsToggle');
  const open = el.classList.toggle('open');
  const S = STRINGS[currentLang];
  btn.textContent = open ? S.termsToggleOpen : S.termsToggle;
});
</script>
