---
// The Claim Decoder — an interactive tool that lets a visitor scan or type
// a skincare marketing claim, then optionally scan the product's
// ingredient list, and get an evidence-based read on whether the two
// actually agree. All matching/evidence-state logic and content below is
// unchanged from the tested prototype; this frontmatter + the Header/
// Footer/BaseHead wiring is the only Astro-specific addition.
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `The Claim Decoder — ${SITE_TITLE}`;
const pageDescription =
	"Scan a skincare claim, then scan the ingredient list — get an evidence-based read on whether this specific product backs up what it says. Runs entirely on-device, no data ever leaves your browser.";
---

<html lang="en">
<head>
<BaseHead title={pageTitle} description={pageDescription} />
<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js" is:inline></script>
<script src="/claims-data.js" is:inline></script>
<style>
  /* Component tokens aliased to the site's real design tokens (see
     src/styles/global.css, loaded globally via BaseHead) rather than
     hand-copied hex values, so this page stays in sync with the rest
     of the site automatically. --coral / --amber / --teal / --white
     are already defined globally and inherited as-is. */
  :root{
    --bg: var(--seafoam-light);
    --card: var(--white);
    --ink: var(--forest);
    --ink-soft: var(--muted);
    --coral-bg: color-mix(in srgb, var(--coral) 12%, white);
    --amber-bg: color-mix(in srgb, var(--amber) 15%, white);
    --teal-bg: var(--seafoam-mid);
    --line: var(--seafoam-border);
    --radius: 20px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--bg);
    background-image: radial-gradient(circle, #d5e5e0 1px, transparent 1px);
    background-size: 22px 22px;
    color:var(--ink);
    font-family:Georgia,'Times New Roman',serif;
    -webkit-font-smoothing:antialiased;
    position:relative;
    overflow-x:hidden;
  }
  .blob{position:fixed; border-radius:50%; filter:blur(40px); z-index:0; pointer-events:none;}
  .blob-1{width:340px;height:340px; top:-100px; right:-120px; background:var(--coral-bg); opacity:.55; animation:drift1 22s ease-in-out infinite alternate;}
  .blob-2{width:280px;height:280px; bottom:0; left:-140px; background:var(--teal-bg); opacity:.6; animation:drift2 26s ease-in-out infinite alternate;}
  @keyframes drift1{0%{transform:translate(0,0);}100%{transform:translate(-30px,40px);}}
  @keyframes drift2{0%{transform:translate(0,0);}100%{transform:translate(30px,-30px);}}

  .wrap{max-width:760px;margin:0 auto;padding:48px 24px 80px;position:relative;z-index:1;}

  .brand{
    font-family:Georgia,'Times New Roman',serif;font-weight:600;font-size:17px;
    color:#1a3a34; letter-spacing:-.01em;
  }
  .brand-row{display:flex; align-items:center; justify-content:flex-end; margin-bottom:20px;}
  .lang-toggle{display:flex; gap:2px; background:#eef4f2; padding:3px; border-radius:8px;}
  .lang-btn{
    border:none; background:transparent; padding:5px 11px; border-radius:6px;
    font-family:Georgia,'Times New Roman',serif; font-size:12.5px; font-weight:700;
    color:#4a7a72; cursor:pointer; letter-spacing:.03em; transition:all .15s ease;
  }
  .lang-btn.active{background:#fff; color:#1a3a34; box-shadow:0 1px 4px rgba(0,0,0,.08);}
  .brand .scale{color:#2d9e88;}
  .brand .dot-mark{
    display:inline-block; width:6px; height:6px; border-radius:50%;
    background:#ff6b6b; margin-left:4px; vertical-align:middle;
    animation:pulse 2s ease-in-out infinite;
  }
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

  .header-row{display:flex; align-items:flex-start; gap:14px; margin-bottom:8px;}
  .flask-icon{flex-shrink:0; margin-top:6px; animation:bob 4s ease-in-out infinite;}
  @keyframes bob{0%,100%{transform:translateY(0) rotate(-4deg);}50%{transform:translateY(-6px) rotate(4deg);}}

  h1{
    font-family:Georgia,'Times New Roman',serif;font-weight:700;font-size:clamp(36px,6vw,52px);
    line-height:1.08;margin:0 0 14px; letter-spacing:-.01em;
    opacity:0; transform:translateY(10px);
    animation:riseIn .6s ease forwards .1s;
  }
  @keyframes riseIn{to{opacity:1; transform:translateY(0);}}
  h1 .accent{color:var(--coral); position:relative; display:inline-block;}
  h1 .accent svg{position:absolute; left:0; bottom:-6px; width:100%; height:10px; overflow:visible;}
  h1 .accent path{stroke-dasharray:280; stroke-dashoffset:280; animation:draw 1s ease forwards .5s;}
  @keyframes draw{to{stroke-dashoffset:0;}}

  .sub{font-size:17px;line-height:1.55;color:var(--ink-soft);margin:0 0 32px;max-width:56ch;}

  .mode-tabs{display:flex; gap:6px; background:#eef4f2; padding:5px; border-radius:14px; margin-bottom:22px; width:fit-content; max-width:100%; overflow-x:auto; -webkit-overflow-scrolling:touch;}
  .mode-tab{
    border:none; background:transparent; padding:10px 18px; border-radius:10px;
    font-family:Georgia,'Times New Roman',serif; font-size:14px; font-weight:600; color:var(--ink-soft);
    cursor:pointer; transition:all .18s ease; display:flex; align-items:center; gap:7px;
    white-space:nowrap; flex-shrink:0;
  }
  .mode-tab.active{background:var(--card); color:var(--ink); box-shadow:0 2px 8px rgba(0,0,0,.06);}
  .mode-tab:hover:not(.active){color:var(--ink);}

  .panel{display:none;}
  .panel.active{display:block; animation:fade .25s ease;}
  @keyframes fade{from{opacity:0;}to{opacity:1;}}

  .input-toggle{display:flex; gap:16px; margin-bottom:18px; align-items:center;}
  .input-toggle-btn{
    background:none; border:none; padding:6px 0; font-family:Georgia,'Times New Roman',serif;
    font-size:14px; font-weight:600; color:var(--ink-soft); cursor:pointer;
    border-bottom:2px solid transparent; transition:color .15s ease, border-color .15s ease;
  }
  .input-toggle-btn.active{color:var(--coral); border-color:var(--coral);}
  .input-toggle-btn:hover:not(.active){color:var(--ink);}

  .type-step{margin-bottom:20px;}
  .type-step textarea{
    width:100%; padding:14px 16px; font-size:15px; font-family:Georgia,'Times New Roman',serif;
    border:1.5px solid var(--line); border-radius:14px; background:var(--card);
    color:var(--ink); outline:none; resize:vertical; transition:border-color .15s ease, box-shadow .15s ease;
    margin-bottom:12px; line-height:1.5;
  }
  .type-step textarea:focus{border-color:var(--coral); box-shadow:0 0 0 4px var(--coral-bg);}
  .type-step textarea::placeholder{color:#8fada5;}
  .input-hint{font-size:12.5px; color:var(--ink-soft); margin:-8px 0 12px;}

  .search-box{position:relative;margin-bottom:24px;}
  .search-box input{
    width:100%;padding:16px 20px;font-size:16px;font-family:Georgia,'Times New Roman',serif;
    border:1.5px solid var(--line);border-radius:14px;background:var(--card);
    color:var(--ink);outline:none;transition:border-color .15s ease, box-shadow .15s ease;
  }
  .search-box input:focus{border-color:var(--coral); box-shadow:0 0 0 4px var(--coral-bg);}
  .search-box input::placeholder{color:#8fada5;}

  .chip-label{font-size:12px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);margin:0 0 12px;}
  .chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:40px;}
  .chip{
    padding:9px 16px;border-radius:999px;border:1.5px solid var(--line);
    background:var(--card);font-family:Georgia,'Times New Roman',serif;font-size:14px;font-weight:500;
    color:var(--ink);cursor:pointer;transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease, color .15s ease, background .15s ease;
  }
  .chip:hover{border-color:var(--coral);color:var(--coral); transform:translateY(-2px); box-shadow:0 6px 14px rgba(255,110,86,.15);}
  .chip.active{background:var(--coral);border-color:var(--coral);color:#fff; transform:translateY(-1px);}
  .chip.hidden{display:none;}
  .chip.pressed{animation:press .28s ease;}
  @keyframes press{0%{transform:scale(1);}40%{transform:scale(.94);}100%{transform:scale(1);}}

  .dropzone{
    border:2px dashed var(--line); border-radius:18px; padding:32px 20px; text-align:center;
    background:var(--card); cursor:pointer; transition:border-color .2s ease, background .2s ease;
    margin-bottom:20px;
  }
  .dropzone:hover, .dropzone.dragover{border-color:var(--coral); background:var(--coral-bg);}
  .dropzone:focus-visible{outline:3px solid var(--coral); outline-offset:2px;}
  .file-error{color:#b33f3f; font-size:13px; font-weight:600; margin:10px 0 0;}
  .sr-only{position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;}
  .dropzone svg{margin-bottom:10px; animation:bob 3.5s ease-in-out infinite;}
  .dropzone p{margin:0; font-size:15px; color:var(--ink-soft);}
  .dropzone p.title{font-weight:600; color:var(--ink); font-size:16px; margin-bottom:4px;}
  input[type=file]{display:none;}

  .preview-wrap{position:relative; border-radius:16px; overflow:hidden; margin-bottom:16px; border:1.5px solid var(--line);}
  .preview-wrap img{display:block; width:100%; max-height:340px; object-fit:cover;}
  .scan-line{
    position:absolute; left:0; right:0; height:3px; background:linear-gradient(90deg, transparent, var(--coral), transparent);
    top:0; box-shadow:0 0 12px 2px var(--coral); display:none;
  }
  .scan-line.active{display:block; animation:scanmove 1.6s ease-in-out infinite;}
  @keyframes scanmove{0%{top:0;}50%{top:calc(100% - 3px);}100%{top:0;}}

  .scan-actions{display:flex; gap:10px; margin-bottom:24px; flex-wrap:wrap;}
  .btn{
    font-family:Georgia,'Times New Roman',serif; font-weight:600; font-size:14.5px; padding:12px 20px;
    border-radius:12px; border:none; cursor:pointer; transition:transform .12s ease, opacity .12s ease;
    display:inline-flex; align-items:center; gap:8px;
  }
  .btn:active{transform:scale(.97);}
  .btn-primary{background:var(--coral); color:#fff;}
  .btn-primary:disabled{opacity:.5; cursor:not-allowed;}
  .btn-ghost{background:var(--card); color:var(--ink-soft); border:1.5px solid var(--line);}
  .btn-sage{background:var(--teal); color:#fff;}

  .scan-status{font-size:14px; color:var(--ink-soft); margin-bottom:16px; display:none; align-items:center; gap:8px;}
  .scan-status.active{display:flex;}
  .spinner{width:14px;height:14px;border:2px solid var(--coral-bg);border-top-color:var(--coral);border-radius:50%;animation:spin .7s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}

  #scanResults .card{margin-bottom:16px;}
  .scan-empty{background:var(--teal-bg); border-radius:16px; padding:20px; font-size:14.5px; color:#1f6e5c; line-height:1.55;}

  .ing-prompt{
    background:var(--card); border:1.5px dashed var(--coral); border-radius:16px; padding:20px;
    margin-bottom:20px; text-align:center;
  }
  .ing-prompt p{margin:0 0 12px; font-size:14.5px; color:var(--ink); line-height:1.5;}
  .ing-prompt .claim-list{font-weight:700; color:var(--coral);}

  .ing-check{
    margin-top:18px; padding:16px 18px; border-radius:14px; font-size:14.5px; line-height:1.6;
    animation:cardIn .3s ease;
  }
  .ing-check.pending{background:#f0f7f5; color:var(--ink-soft); font-style:italic;}
  .ing-check.flagged{background:var(--coral-bg); color:#b33f3f; border:1.5px solid #f0b8b8;}
  .ing-check.flagged h4{margin:0 0 6px; font-size:12.5px; text-transform:uppercase; letter-spacing:.06em; color:#b33f3f;}
  .ing-check.clear{background:var(--teal-bg); color:#1f6e5c; border:1.5px solid #c8e0da;}
  .ing-check.clear h4{margin:0 0 6px; font-size:12.5px; text-transform:uppercase; letter-spacing:.06em; color:#1f6e5c;}
  .ing-check.info{background:var(--amber-bg); color:#8a6510; border:1.5px solid #e8c97a;}
  .ing-check.info h4{margin:0 0 6px; font-size:12.5px; text-transform:uppercase; letter-spacing:.06em; color:#8a6510;}

  #result{display:none;}
  #result.show{display:block;animation:cardIn .3s ease;}
  @keyframes cardIn{from{opacity:0;transform:translateY(10px) scale(.98);}to{opacity:1;transform:translateY(0) scale(1);}}

  .card{background:var(--card);border-radius:var(--radius);padding:32px;border:1.5px solid var(--line); box-shadow:0 4px 20px rgba(43,38,32,.04);}

  .evidence-banner{display:flex; gap:12px; align-items:flex-start; padding:16px 18px; border-radius:14px; margin-bottom:20px;}
  .evidence-icon{font-size:22px; line-height:1;}
  .evidence-label{font-weight:700; font-size:15px; margin-bottom:3px;}
  .evidence-sub{font-size:13.5px; line-height:1.5; opacity:.9;}
  .evidence-banner.sage{background:var(--teal-bg); color:#1f6e5c;}
  .evidence-banner.coral{background:var(--coral-bg); color:#b33f3f;}
  .evidence-banner.amber{background:var(--amber-bg); color:#8a6510;}
  .evidence-banner.neutral{background:#eef4f2; color:#4a7a72;}
  .ing-cta{background:#f0f7f5; border:1.5px dashed var(--line); border-radius:14px; padding:14px 16px; margin-top:20px; font-size:14px; color:var(--ink-soft); font-style:italic;}
  .fragrance-note{background:var(--amber-bg); border-radius:14px; padding:14px 16px; margin-top:20px; font-size:14px; color:#8a6510; line-height:1.5;}
  .card-footer{display:flex; flex-wrap:wrap; gap:6px 14px; font-size:12px; color:var(--ink-soft); margin-top:24px; padding-top:16px; border-top:1px solid var(--line);}
  .card-footer a{color:var(--coral); text-decoration:underline;}
  .confidence-note{font-size:11.5px; color:var(--ink-soft); font-style:italic; line-height:1.5;}
  .source a{color:var(--coral); text-decoration:underline; word-break:break-word;}
  .section ul{margin:0; padding-left:18px; font-size:15px; line-height:1.6; color:var(--ink);}
  .section li{margin-bottom:4px;}
  .badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:16px;}
  .badge.unregulated{background:var(--coral-bg);color:#b33f3f;}
  .badge.weak{background:var(--amber-bg);color:#8a6510;}
  .badge.verified{background:var(--teal-bg);color:#1f6e5c;}
  .card h2{font-family:Georgia,'Times New Roman',serif;font-weight:600;font-size:26px;margin:0 0 6px;}
  .verdict{font-size:17px;line-height:1.5;color:var(--ink);font-weight:500;margin:0 0 24px;padding-bottom:20px;border-bottom:1px solid var(--line);}
  .section{margin-bottom:20px;}
  .section:last-of-type{margin-bottom:0;}
  .section h3{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);margin:0 0 6px;}
  .section p{font-size:15.5px;line-height:1.6;margin:0;color:var(--ink);}
  .section.catch h3{color:#b33f3f;}
  .section.lookfor{background:var(--teal-bg);border-radius:14px;padding:16px 18px;margin-top:24px;}
  .section.lookfor h3{color:#1f6e5c;}
  .source{margin-top:22px;font-size:12.5px;color:var(--ink-soft);font-style:italic;}
  .empty{text-align:center;padding:40px 20px;color:var(--ink-soft);font-size:14px;}
  .tool-footer{margin-top:56px;padding-top:24px;border-top:1px solid var(--line);font-size:12.5px;line-height:1.6;color:var(--ink-soft);}
  .terms-toggle{
    background:none;border:none;padding:0;margin-top:14px;font-family:Georgia,'Times New Roman',serif;
    font-size:12.5px;font-weight:600;color:var(--coral);cursor:pointer;text-decoration:underline;
    text-underline-offset:2px;
  }
  .terms-full{max-height:0;overflow:hidden;transition:max-height .35s ease;}
  .terms-full.open{max-height:600px;}
  .terms-full-inner{padding-top:16px;}
  .terms-full-inner p{margin:0 0 12px;}
  .terms-full-inner ul{margin:0 0 12px;padding-left:18px;}
  .terms-full-inner li{margin-bottom:8px;}
  .disclaimer-main{margin:0 0 14px; font-size:12.5px; line-height:1.6;}
  .privacy-line{margin:0 0 14px; font-size:12.5px; line-height:1.6; background:var(--teal-bg); color:#1f6e5c; padding:12px 14px; border-radius:12px;}
</style>
</head>
<body>
<Header />
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="wrap">

  <div class="brand-row">
    <div class="lang-toggle" role="group" aria-label="Language / Idioma">
      <button class="lang-btn active" id="langBtnEn" data-lang="en">EN</button>
      <button class="lang-btn" id="langBtnEs" data-lang="es">ES</button>
    </div>
  </div>

  <div class="header-row">
    <svg class="flask-icon" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
    </svg>
    <h1><span data-i18n="h1part1">The Claim </span><span class="accent"><span data-i18n="h1part2">Decoder</span><svg viewBox="0 0 260 10" preserveAspectRatio="none"><path d="M2,6 Q65,1 130,5 Q195,9 258,3" stroke="#ff6b6b" stroke-width="3" fill="none" stroke-linecap="round"/></svg></span></h1>
  </div>
  <p class="sub" data-i18n="subtitle">Every skincare label makes promises. Some are regulated. Most aren't. Scan a claim, then scan the ingredient list — we'll tell you if this specific bottle backs up what it says.</p>

  <div class="mode-tabs">
    <button class="mode-tab active" data-mode="search" data-i18n="tabSearch">🔎 Search &amp; Browse</button>
    <button class="mode-tab" data-mode="scan" data-i18n="tabCheck">🧴 Check a Product</button>
  </div>

  <div class="panel active" id="searchPanel">
    <div class="search-box">
      <label for="searchInput" class="sr-only" data-i18n="searchLabel">Search for a skincare claim</label>
      <input type="text" id="searchInput" data-i18n-placeholder="searchPlaceholder" placeholder='Type a claim — e.g. "clean," "hypoallergenic," "reef safe"…' autocomplete="off">
    </div>
    <p class="chip-label" data-i18n="browseAll">Or browse all claims</p>
    <div class="chips" id="chipContainer"></div>
    <div id="result" aria-live="polite"></div>
    <div class="empty" id="emptyState" role="status" data-i18n="emptyState">Nothing matches that yet — try a shorter word, or browse the list above.</div>
  </div>

  <div class="panel" id="scanPanel">

    <div class="input-toggle">
      <button class="input-toggle-btn active" data-input="scan" data-i18n="toggleScan">📸 Scan a Label</button>
      <button class="input-toggle-btn" data-input="type" data-i18n="toggleType">⌨️ Type or Paste Instead</button>
    </div>

    <div id="scanInputPanel">
      <div id="step1">
        <div class="dropzone" id="dropzone1" tabindex="0" role="button" aria-label="Upload or take a photo of the claim on the front label">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 7h3l1.5-2h7L17 7h3a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1z"/>
            <circle cx="12" cy="13" r="3.5"/>
          </svg>
          <p class="title" data-i18n="step1Title">Step 1 — Photo of the claim</p>
          <p data-i18n="step1Sub">Front of bottle — "reef safe," "clean," "paraben-free," etc.</p>
        </div>
        <input type="file" id="fileInput1" accept="image/*" capture="environment">

        <div id="previewSection1" style="display:none;">
          <div class="preview-wrap">
            <img id="previewImg1" src="" alt="Claim photo">
            <div class="scan-line" id="scanLine1"></div>
          </div>
          <div class="scan-actions">
            <button class="btn btn-primary" id="decodeBtn1" data-i18n="readPhoto">🔍 Read This Photo</button>
            <button class="btn btn-ghost" id="retakeBtn1" data-i18n="tryAnother">Try another photo</button>
          </div>
        </div>
        <div class="scan-status" id="scanStatus1"><span class="spinner"></span><span id="scanStatusText1" data-i18n="readingLabel">Reading the label…</span></div>
      </div>
    </div>

    <div id="typeInputPanel" style="display:none;">
      <div class="type-step">
        <p class="chip-label" data-i18n="typeClaimLabel">Type or paste the claim</p>
        <textarea id="claimTextInput" rows="3" data-i18n-placeholder="claimPlaceholder" placeholder='e.g. "Reef Safe" — or paste the full front-label text' aria-label="Claim text"></textarea>
        <button class="btn btn-primary" id="analyzeClaimBtn" data-i18n="decodeClaim">✨ Decode This Claim</button>
        <p class="input-hint" id="claimTextHint" role="status" aria-live="polite"></p>
      </div>
    </div>

    <div id="scanResults" aria-live="polite"></div>
    <div id="ingPromptWrap"></div>

    <div id="step2" style="display:none;">
      <p class="chip-label" style="margin-top:8px;" data-i18n="step2Title">Step 2 — Photo of the ingredient list</p>
      <div class="dropzone" id="dropzone2" tabindex="0" role="button" aria-label="Upload or take a photo of the ingredient list">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#2d9e88" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 7h3l1.5-2h7L17 7h3a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1z"/>
          <circle cx="12" cy="13" r="3.5"/>
        </svg>
        <p class="title" data-i18n="ingPhotoTitle">Photo of the ingredient list</p>
        <p data-i18n="ingPhotoSub">Usually on the back — the small-print INCI list</p>
      </div>
