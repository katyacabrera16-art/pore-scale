---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const now = new Date();
const posts = (await getCollection('blog'))
	.filter((post) => import.meta.env.PROD ? post.data.pubDate <= now : true)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				background: #f7fbfa;
			}
			.hero {
				max-width: 760px;
				margin: 0 auto;
				padding: 5rem 2rem 4rem;
				text-align: center;
				border-bottom: 1px solid #c8e0da;
			}
			.masthead {
				display: block;
				line-height: 1;
				margin-bottom: 1rem;
			}
			.masthead-pore {
				display: inline;
				font-size: 4.5rem;
				font-weight: 900;
				color: #1a3a34;
				letter-spacing: -0.03em;
				vertical-align: baseline;
			}
			.masthead-scale {
				display: inline;
				font-size: 5.5rem;
				font-weight: 900;
				color: #2d9e88;
				letter-spacing: -0.03em;
				vertical-align: baseline;
			}
			.masthead .dot {
				color: #ff6b6b;
			}
			.eyebrow {
				display: block;
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #2d9e88;
				margin-bottom: 1.25rem;
			}
			.hero h1 {
				font-size: clamp(2rem, 5vw, 3.2rem);
				font-weight: 800;
				color: #1a3a34;
				line-height: 1.15;
				margin: 0 0 1.25rem;
			}
			.hero-subtitle {
				font-size: 1.1rem;
				color: #4a7a72;
				line-height: 1.7;
				margin: 0 0 2rem;
			}
			.cta-button {
				display: inline-block;
				background: #2d9e88;
				color: #fff;
				text-decoration: none;
				font-weight: 700;
				font-size: 0.95rem;
				padding: 0.75rem 2rem;
				border-radius: 4px;
				letter-spacing: 0.03em;
				transition: background 0.2s;
			}
			.cta-button:hover {
				background: #1a7a68;
			}
			.latest-section {
				max-width: 760px;
				margin: 0 auto;
				padding: 0 2rem 5rem;
			}
			.section-label {
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: #2d9e88;
				margin-bottom: 1.5rem;
			}
			.post-cards {
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
			}
			.post-card {
				background: #fff;
				border: 1px solid #c8e0da;
				border-radius: 8px;
				padding: 1.75rem 2rem;
				text-decoration: none;
				color: inherit;
				display: block;
				transition: box-shadow 0.2s;
			}
			.post-card:hover {
				box-shadow: 0 4px 16px rgba(45, 158, 136, 0.1);
			}
			.card-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 0.6rem;
			}
			.card-date {
				font-size: 0.8rem;
				color: #4a7a72;
			}
			.card-category {
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: #ff6b6b;
			}
			.card-title {
				font-size: 1.15rem;
				font-weight: 700;
				color: #1a3a34;
				margin: 0 0 0.5rem;
				line-height: 1.3;
			}
			.card-excerpt {
				font-size: 0.9rem;
				color: #4a7a72;
				line-height: 1.6;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<span class="masthead"><span class="masthead-pore">Pore</span> <span class="masthead-scale">Scale<span class="dot">.</span></span></span>
				<span class="eyebrow">Skincare × Environment × Science</span>
				<h1>Better skincare begins with better understanding.</h1>
				<p class="hero-subtitle">Science-backed insights on ingredients, packaging, and the environmental footprint of beauty.</p>
				<a class="cta-button" href="/blog">Start Reading</a>
			</section>

			<section class="latest-section">
				<p class="section-label">Latest</p>
				<div class="post-cards">
					{posts.map((post) => (
						<a class="post-card" href={`/blog/${post.id}/`}>
							<div class="card-meta">
								<span class="card-date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.category && <span class="card-category">{post.data.category}</span>}
							</div>
							<h2 class="card-title">{post.data.title}</h2>
							<p class="card-excerpt">{post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

