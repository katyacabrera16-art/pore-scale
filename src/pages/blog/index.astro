---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import DualLanguageCard from '../../components/DualLanguageCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const now = new Date();
const allPosts = (await getCollection('blog'))
	.filter((post) => import.meta.env.PROD ? post.data.pubDate <= now : true);

const grouped = Object.values(
	allPosts.reduce((acc, post) => {
		const key = post.data.slug;
		if (!acc[key]) {
			acc[key] = { slug: key, en: null, es: null, pubDate: post.data.pubDate, category: post.data.category };
		}
		acc[key][post.data.lang] = post;
		return acc;
	}, {} as Record<string, any>)
).sort((a, b) => b.pubDate - a.pubDate);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 760px;
				margin: 0 auto;
				padding: 3rem 1.5rem;
			}
			.page-header {
				margin-bottom: 3rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--seafoam-border);
			}
			.page-header h1 {
				font-size: 2rem;
				color: var(--teal);
				margin: 0 0 0.25rem;
			}
			.page-header p {
				color: var(--muted);
				font-size: 0.95rem;
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>All Posts</h1>
				<p>{grouped.length} {grouped.length === 1 ? 'entry' : 'entries'}</p>
			</div>
			{grouped.map((group) => (
				<DualLanguageCard
					en={group.en}
					es={group.es}
					pubDate={group.pubDate}
					category={group.category}
				/>
			))}
		</main>
		<Footer />
	</body>
</html>
